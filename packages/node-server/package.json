{
  "name": "@ts-zero/node-server",
  "version": "0.0.0",
  "description": "Zero-dependency Node HTTP adapter for ts-zero Web Standard handlers.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./serve": {
      "types": "./dist/serve.d.ts",
      "default": "./dist/serve.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {}
}
