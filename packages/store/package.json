{
  "name": "@ts-zero/store",
  "version": "0.0.0",
  "description": "Zero-dependency deterministic immutable state engine for authoritative and replicated runtimes.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./create": {
      "types": "./dist/create.d.ts",
      "default": "./dist/create.js"
    },
    "./freeze": {
      "types": "./dist/freeze.d.ts",
      "default": "./dist/freeze.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot.d.ts",
      "default": "./dist/snapshot.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {}
}
