{
  "name": "@ts-zero/multipart",
  "version": "0.0.0",
  "description": "Zero-dependency multipart/form-data encoder for TypeScript.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./boundary": {
      "types": "./dist/boundary.d.ts",
      "default": "./dist/boundary.js"
    },
    "./encode": {
      "types": "./dist/encode.d.ts",
      "default": "./dist/encode.js"
    },
    "./parts": {
      "types": "./dist/parts.d.ts",
      "default": "./dist/parts.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {}
}
