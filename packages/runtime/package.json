{
  "name": "@ts-zero/runtime",
  "version": "0.0.0",
  "description": "Zero-dependency cross-surface runtime primitives for TypeScript.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./channel": {
      "types": "./dist/channel.d.ts",
      "default": "./dist/channel.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./handles": {
      "types": "./dist/handles.d.ts",
      "default": "./dist/handles.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./serializable": {
      "types": "./dist/serializable.d.ts",
      "default": "./dist/serializable.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {}
}
