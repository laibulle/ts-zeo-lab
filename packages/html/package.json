{
  "name": "@ts-zero/html",
  "version": "0.0.0",
  "description": "Zero-dependency HTML UI runtime for store-driven browser interfaces.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "default": "./dist/actions.js"
    },
    "./bindings": {
      "types": "./dist/bindings.d.ts",
      "default": "./dist/bindings.js"
    },
    "./elements": {
      "types": "./dist/elements.d.ts",
      "default": "./dist/elements.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./mount": {
      "types": "./dist/mount.d.ts",
      "default": "./dist/mount.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {}
}
